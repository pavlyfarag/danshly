# Canonical origin of the deployed site (used for metadata, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://danshly.com

# Optional: where contact-form submissions are delivered as JSON.
# Point this at any self-hosted receiver (ntfy, n8n, Mattermost webhook, …).
# When unset, submissions are emitted as structured logs (picked up by the
# container runtime / Loki).
CONTACT_WEBHOOK_URL=
